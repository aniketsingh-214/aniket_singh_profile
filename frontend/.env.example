# ── Frontend Environment Variables ────────────────────────────────────────────

# 1. Backend API URL
# Local (using Vite proxy): Leave empty or /api
# Production: Your deployed backend URL (e.g., https://your-backend.onrender.com)
VITE_API_BASE_URL=

# 2. Repository Name (Used for GitHub Pages sub-paths)
# Leave empty if deploying to a custom domain or root path.
VITE_REPO_NAME=
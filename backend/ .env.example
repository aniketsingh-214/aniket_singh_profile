# ── Backend Environment Variables ─────────────────────────────────────────────
# This file contains the necessary variables for deployment.
# Rename this to .env and fill in the missing values.

# 1. Port for the server to listen on (default: 5000)
PORT=5000

# 2. Frontend Origin (Used for CORS protection)
# Local: http://localhost:5173
# Production: Your deployed frontend URL (e.g., https://aniketsingh.github.io)
FRONTEND_ORIGIN=http://localhost:5173

# 3. Email Credentials (SMTP - Gmail recommended)
# Note: For Gmail, use an "App Password" (NOT your primary account password)
EMAIL_USER=aniketsingh7141340@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# 4. Email Configuration
# The address that will RECEIVE the contact form submissions
CONTACT_RECEIVER_EMAIL=infoaniketsinghprofile@gmail.com
# The name that will appear as the sender in user acknowledgement emails
SENDER_NAME="Aniket Singh"
